# Xin Agent Runtime — Docker Compose 环境变量
# 复制此文件为 .env 并修改值

# Redis 密码
REDIS_PASSWORD=xruntime-redis-dev

# JWT 签名密钥（生产环境请使用强随机值）
JWT_SECRET=change-me-to-a-secure-random-secret

# API Key 记录（JSON 数组）
# 格式: [{"key":"sk-xxx","tenant_id":"acme","user_id":"alice","role":"admin","kb_ids":["kb1"]}]
API_KEY_RECORDS=[{"key":"sk-admin-dev","tenant_id":"acme","user_id":"alice","role":"admin","kb_ids":["kb1"]}]

# 服务端口
XRUNTIME_PORT=8900
