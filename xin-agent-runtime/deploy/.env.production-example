# ============================================
# XRuntime 生产环境配置示例
# --------------------------------------------
# 此文件包含一套模拟的生产环境配置值
# 实际部署时请替换为真实值
# 生成密钥: openssl rand -hex 32
# 环境变量格式: XRUNTIME_<SECTION>_<FIELD>
# ============================================

# ============================================
# 🔒 核心运行配置
# ============================================
XRUNTIME_PRODUCTION=1
XRUNTIME_ENABLE_ENTERPRISE_MIDDLEWARES=true
XRUNTIME_SERVER_AUTH_ENABLED=true
XRUNTIME_SERVER_HOST=0.0.0.0
XRUNTIME_SERVER_PORT=8900

# ============================================
# 🔑 认证配置
# ============================================
XRUNTIME_API_KEYS=changeme-xrk-prod-1,changeme-xrk-prod-2
XRUNTIME_JWT_SECRET=changeme-jsk-prod
XRUNTIME_PERMISSION_DEFAULT_ROLE=viewer

# ============================================
# 🗄️ Redis 配置
# ============================================
XRUNTIME_STORAGE_REDIS_HOST=redis
XRUNTIME_STORAGE_REDIS_PORT=6379
XRUNTIME_STORAGE_REDIS_DB=0
XRUNTIME_STORAGE_REDIS_PASSWORD=${REDIS_PASSWORD:-xruntime_redis_change_me}
XRUNTIME_STORAGE_TENANT_PREFIX=tenant:{tid}:

XRUNTIME_MESSAGE_BUS_REDIS_HOST=redis
XRUNTIME_MESSAGE_BUS_REDIS_PORT=6379
XRUNTIME_MESSAGE_BUS_REDIS_DB=1
XRUNTIME_MESSAGE_BUS_REDIS_PASSWORD=${REDIS_PASSWORD:-xruntime_redis_change_me}

# ============================================
# 📦 Workspace 沙箱配置
# ============================================
XRUNTIME_WORKSPACE_BACKEND=docker
XRUNTIME_ALLOW_LOCAL_WORKSPACE=0
XRUNTIME_WORKSPACE_DIR=/var/lib/xruntime/workspaces

# ============================================
# 💡 模型配置 (通过 model_providers 配置)
# ============================================
XRUNTIME_MODEL_PROVIDER=anthropic
XRUNTIME_MODEL_API_KEY=changeme-sk-ant-prod
XRUNTIME_MODEL_NAME=claude-3-sonnet-20240229
XRUNTIME_MODEL_BASE_URL=

# ============================================
# 💰 Quota 配额配置
# ============================================
XRUNTIME_MAX_BUDGET_PER_SESSION=10.0
XRUNTIME_RATE_LIMIT=1000/60

# ============================================
# 📚 知识库配置
# ============================================
XRUNTIME_KNOWLEDGE_ENABLED=true
XRUNTIME_KNOWLEDGE_BACKEND=llm_wiki
XRUNTIME_KNOWLEDGE_MODE=static_control
XRUNTIME_KNOWLEDGE_RAW_DIR=/var/lib/xruntime/kb-raw
XRUNTIME_KNOWLEDGE_COMPILED_DIR=/var/lib/xruntime/kb-compiled
XRUNTIME_KNOWLEDGE_RETRIEVAL_TOP_K=5
XRUNTIME_KNOWLEDGE_AUTO_COMPILE=true

# ============================================
# 🔍 Langfuse 可观测性配置 (observability 段)
# ============================================
XRUNTIME_OBSERVABILITY_LANGFUSE_ENABLED=true
XRUNTIME_OBSERVABILITY_LANGFUSE_HOST=https://langfuse.internal.example.com
XRUNTIME_OBSERVABILITY_LANGFUSE_PUBLIC_KEY=changeme-pk-lf-prod
XRUNTIME_OBSERVABILITY_LANGFUSE_SECRET_KEY=changeme-sk-lf-prod
XRUNTIME_OBSERVABILITY_AUDIT_ENABLED=true
XRUNTIME_OBSERVABILITY_AUDIT_STORAGE=redis

# ============================================
# 📊 OpenTelemetry 配置 (observability 段)
# ============================================
XRUNTIME_OBSERVABILITY_OTEL_ENABLED=true
XRUNTIME_OBSERVABILITY_OTEL_ENDPOINT=http://otel-collector:4317

# ============================================
# 🚀 Docker 部署默认值 (内置使用, 非配置schema)
# ============================================
XRUNTIME_WORKERS=4
XRUNTIME_LOG_LEVEL=INFO
