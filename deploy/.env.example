# ============================================
# XRuntime 生产环境配置模板
# ============================================
# 复制此文件为 .env 并修改实际值
# 包含所有可配置项及其说明
# ============================================

# ============================================
# 🔒 安全配置
# ============================================

# 生产模式开关
# 0 = 开发模式 (允许 local workspace, 详细日志)
# 1 = 生产模式 (强制安全默认值)
XRUNTIME_PRODUCTION=1

# API Key 认证 - 逗号分隔多个密钥
# 生产环境请使用长随机字符串，长度建议 64+ 字符
# 生成: openssl rand -hex 32
XRUNTIME_API_KEYS=your-api-key-1,your-api-key-2

# JWT 签名密钥
# 生产环境必须使用强随机密钥，至少 32 字符
# 生成: openssl rand -hex 32
XRUNTIME_JWT_SECRET=your-jwt-secret-at-least-32-characters

# ============================================
# 🗄️ Redis 配置 (存储 + 消息总线)
# ============================================

# Redis 主机 - 生产建议使用集群或 Sentinel
XRUNTIME_STORAGE_REDIS_HOST=redis
XRUNTIME_MESSAGE_BUS_REDIS_HOST=redis

# Redis 端口
XRUNTIME_STORAGE_REDIS_PORT=6379
XRUNTIME_MESSAGE_BUS_REDIS_PORT=6379

# Redis 密码 (生产环境必须设置)
XRUNTIME_REDIS_PASSWORD=your-secure-redis-password

# Redis 数据库编号
XRUNTIME_STORAGE_REDIS_DB=0
XRUNTIME_MESSAGE_BUS_REDIS_DB=1

# Redis 连接池大小
XRUNTIME_REDIS_MAX_CONNECTIONS=50

# ============================================
# 📦 Workspace 沙箱配置
# ============================================

# Workspace 后端
# local = 本地文件系统 (仅开发)
# docker = Docker 容器隔离 (生产默认)
# e2b = E2B 云沙箱
XRUNTIME_WORKSPACE_BACKEND=docker

# 是否允许生产环境使用 local 后端
# 仅特殊内网部署启用，公网必须保持 0
XRUNTIME_ALLOW_LOCAL_WORKSPACE=0

# Workspace 数据根目录
# 生产建议使用独立磁盘挂载
XRUNTIME_WORKSPACE_DIR=/var/lib/xruntime/workspaces

# 单会话工作目录最大空间 (MB)
XRUNTIME_WORKSPACE_QUOTA_MB=500

# ============================================
# 💡 模型配置
# ============================================

# 默认模型
XRUNTIME_DEFAULT_MODEL=claude-3-sonnet

# 备用模型 (主模型不可用时)
XRUNTIME_FALLBACK_MODEL=claude-3-haiku

# 租户允许的模型列表 (逗号分隔)
# 空 = 允许所有已注册模型
XRUNTIME_TENANT_ALLOWED_MODELS=claude-3-opus,claude-3-sonnet,claude-3-haiku

# ============================================
# 💰 Quota 配额配置
# ============================================

# 单会话最大预算 (USD)
# 超过后拒绝新的 LLM 调用
XRUNTIME_MAX_BUDGET_PER_SESSION=10.0

# 单租户每日预算 (USD)
XRUNTIME_DAILY_BUDGET_PER_TENANT=100.0

# 单用户每日最大 Token 数
XRUNTIME_DAILY_TOKENS_PER_USER=1000000

# 最大请求并发数
XRUNTIME_MAX_CONCURRENT_REQUESTS=10

# ============================================
# 📚 知识库配置
# ============================================

# 知识库启用开关
XRUNTIME_KNOWLEDGE_ENABLED=1

# 知识库后端
# llm_wiki = 内置 LLM-Wiki 编译器
# pinecone = Pinecone 向量库
# qdrant = Qdrant 向量库
XRUNTIME_KNOWLEDGE_BACKEND=llm_wiki

# 知识库数据目录
XRUNTIME_KNOWLEDGE_DIR=/var/lib/xruntime/knowledge

# 每次检索返回的 Chunk 数量
XRUNTIME_KNOWLEDGE_TOP_K=5

# Chunk 大小 (Token)
XRUNTIME_KNOWLEDGE_CHUNK_SIZE=512

# Chunk 重叠 (Token)
XRUNTIME_KNOWLEDGE_CHUNK_OVERLAP=50

# ============================================
# 🔍 Langfuse 可观测性配置
# ============================================

# Langfuse 追踪启用
LANGFUSE_ENABLED=0

# Langfuse 服务地址 (自托管或 SaaS)
LANGFUSE_HOST=https://cloud.langfuse.com

# Langfuse API 密钥
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxx

# 追踪采样率 (0-1)
# 1 = 全部追踪, 0.1 = 10% 采样
LANGFUSE_SAMPLE_RATE=1.0

# ============================================
# 📊 OpenTelemetry 配置
# ============================================

# OTel 启用开关
OTEL_ENABLED=0

# OTel Collector 地址
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# 服务名称
OTEL_SERVICE_NAME=xruntime

# 环境标识
OTEL_ENVIRONMENT=production

# ============================================
# 🌐 HTTP 服务配置
# ============================================

# 服务监听地址
XRUNTIME_HTTP_HOST=0.0.0.0
XRUNTIME_HTTP_PORT=8900

# Worker 进程数 (建议 = CPU 核心数)
XRUNTIME_WORKERS=4

# 单进程最大线程数
XRUNTIME_THREADS_PER_WORKER=8

# 请求超时 (秒)
XRUNTIME_REQUEST_TIMEOUT=120

# 保持连接超时
XRUNTIME_KEEPALIVE_TIMEOUT=5

# ============================================
# 🚦 限流配置
# ============================================

# 限流启用开关
XRUNTIME_RATE_LIMIT_ENABLED=1

# 时间窗口 (秒)
XRUNTIME_RATE_LIMIT_WINDOW=60

# 窗口内最大请求数
XRUNTIME_RATE_LIMIT_MAX_REQUESTS=1000

# 每 IP 限流 (覆盖全局)
# 格式: ip1:max1,ip2:max2
# XRUNTIME_IP_RATE_LIMITS=10.0.0.1:2000,192.168.1.1:500

# ============================================
# 📝 日志配置
# ============================================

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
XRUNTIME_LOG_LEVEL=INFO

# 日志格式: json, text
XRUNTIME_LOG_FORMAT=json

# 日志文件路径
XRUNTIME_LOG_FILE=/var/log/xruntime/xruntime.log

# 审计日志路径
XRUNTIME_AUDIT_LOG_FILE=/var/log/xruntime/audit.log

# 日志轮转: 单文件最大大小 (MB)
XRUNTIME_LOG_MAX_SIZE_MB=100

# 日志轮转: 保留文件数
XRUNTIME_LOG_BACKUP_COUNT=10

# ============================================
# 🔌 技能/工具配置
# ============================================

# 技能目录 (逗号分隔)
XRUNTIME_SKILL_DIRS=/etc/xruntime/skills

# 自动加载技能
XRUNTIME_SKILL_AUTO_LOAD=1

# 工具执行超时 (秒)
XRUNTIME_TOOL_TIMEOUT=30

# 危险工具黑名单 (逗号分隔)
# XRUNTIME_TOOL_BLACKLIST=rm,dd,mkfs

# ============================================
# 🧠 中间件配置
# ============================================

# 启用的中间件 (逗号分隔，顺序重要)
# 可用: rbac, audit, quota, secret_redaction, knowledge, skill_injection, memory, loop_detection, langfuse
XRUNTIME_MIDDLEWARES=rbac,audit,quota,secret_redaction,knowledge,skill_injection,memory,loop_detection,langfuse

# 默认角色 (最小权限原则)
# viewer, contributor, admin, owner
XRUNTIME_DEFAULT_ROLE=viewer

# ============================================
# 🧪 调试配置 (生产环境禁用!)
# ============================================

# 调试模式 (生产环境必须设为 0)
XRUNTIME_DEBUG=0

# 详细错误堆栈
XRUNTIME_VERBOSE_ERRORS=0

# 测试模式 (绕过实际模型调用)
XRUNTIME_TEST_MODE=0

# ============================================
# 🚀 高级配置
# ============================================

# 最大并发 Agent 数
XRUNTIME_MAX_AGENTS=100

# Agent 最大交互轮数
XRUNTIME_MAX_TURNS=50

# 会话空闲超时 (秒)
XRUNTIME_SESSION_IDLE_TIMEOUT=3600

# 事件队列大小
XRUNTIME_EVENT_QUEUE_SIZE=10000

# ============================================
# 📋 配置说明
# ============================================
#
# 修改配置后需要重启服务生效
#
# 最低要求配置项:
#   - XRUNTIME_PRODUCTION=1
#   - XRUNTIME_API_KEYS
#   - XRUNTIME_JWT_SECRET
#   - XRUNTIME_REDIS_PASSWORD
#   - XRUNTIME_WORKSPACE_BACKEND=docker
#
# 安全建议:
#   - 不要将真实密钥提交到版本控制
#   - 使用 Docker Secrets 或 Vault 管理敏感配置
#   - 定期轮换 API Key 和 JWT Secret
#   - 限制 Redis 仅内网访问
#   - 生产环境必须启用 TLS (通过反向代理)
